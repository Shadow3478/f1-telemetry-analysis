APP_NAME="PitWall F1 Telemetry API"
DATABASE_URL="sqlite:///./pitwall.db"

# ── Environment ──────────────────────────────────────────────────────────
# Set to "production" on Render (enables production validation, disables preloader)
ENVIRONMENT="development"

# ── Redis / Celery ───────────────────────────────────────────────────────
# Local development: localhost Redis (install Redis or use Docker)
# Production (Render): Set REDIS_URL to your managed Redis instance URL.
#   Free option: Upstash Redis (https://upstash.com) — free tier, 10K commands/day
#   Paid option: Render Redis add-on ($7/month)
# If no Redis is available, analysis runs in background threads (works but uses more memory).
REDIS_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND=""

# ── Preloader ────────────────────────────────────────────────────────────
# Set to true to disable the in-process preloader (recommended on Render Hobby plan)
DISABLE_PRELOADER=false

# ── Data ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=["*"]
TELEMETRY_DATA_DIR="./data/telemetry"
FASTF1_CACHE_DIR="./data/fastf1-cache"
REPORTS_DIR="./data/reports"
USE_LIVE_DATA=true
OPENF1_BASE_URL="https://api.openf1.org/v1"
ERGAST_BASE_URL="https://api.jolpi.ca/ergast/f1"

# ── Analysis tuning ─────────────────────────────────────────────────────
DISTANCE_SAMPLES=1000
ENSEMBLE_MIN_LAPS=3
ENSEMBLE_MAX_LAPS=5
INSIGHT_CONSISTENCY_THRESHOLD=0.60
