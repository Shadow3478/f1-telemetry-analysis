APP_NAME="PitWall F1 Telemetry API"
DATABASE_URL="sqlite:///./pitwall.db"
REDIS_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/1"
CORS_ORIGINS=["*"]
TELEMETRY_DATA_DIR="./data/telemetry"
FASTF1_CACHE_DIR="./data/fastf1-cache"
REPORTS_DIR="./data/reports"
USE_LIVE_DATA=true
OPENF1_BASE_URL="https://api.openf1.org/v1"
ERGAST_BASE_URL="https://api.jolpi.ca/ergast/f1"
DISTANCE_SAMPLES=1000
ENSEMBLE_MIN_LAPS=3
ENSEMBLE_MAX_LAPS=5
INSIGHT_CONSISTENCY_THRESHOLD=0.60
